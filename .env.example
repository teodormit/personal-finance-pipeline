# =============================================================================
# .env.example — committed template. Copy to .env and fill in real values.
# =============================================================================
# The real .env is gitignored; never commit credentials. On a fresh machine:
#     cp .env.example .env
#     # then edit .env with your values
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
# POSTGRES_HOST is "localhost" for host-based dev (Python on host hitting
# containerized Postgres via mapped 5432). Inside the pipeline container,
# docker-compose.yml overrides this to "postgres" (the service name).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=finance_warehouse

# --- BudgetBakers API --------------------------------------------------------
# Generate at https://web.budgetbakers.com → API tokens. Keep secret.
BUDGETBAKERS_API_TOKEN=your_budgetbakers_api_token_here

# --- MinIO (optional, not used by the pipeline today) -----------------------
# Left in for future Phase D / object-storage work. MinIO service is currently
# removed from docker-compose.yml; these vars are inert until it returns.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
