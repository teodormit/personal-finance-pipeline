# =====================================================
# Secrets & credentials (NEVER commit)
# =====================================================
.env
*.env
secrets/
credentials/
*.pem
*.key
client_secret_*.json
*-service-account*.json

# =====================================================
# Personal financial data (NEVER commit)
# =====================================================
data/raw/*
data/processed/*
data/archive/*
data/inspection/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/archive/.gitkeep
!data/inspection/.gitkeep

# Spreadsheet exports anywhere in the tree
*.xlsx
*.xls
*.csv

# Standalone analysis scripts working on personal data
data_check_scripts/

# =====================================================
# PostgreSQL data dirs (must never be in repo)
# =====================================================
data.backup/
data/base/
data/global/
data/pg_*/
data/postmaster.*
*.conf.backup
postgres_data/
minio_data/

# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# =====================================================
# Logs & temp
# =====================================================
logs/
*.log
tmp/
temp/
*.tmp
*.backup
*.bak

# =====================================================
# SQL - keep private (owner-specific seeds + grants).
# Public sanitized blueprint is the only exception.
# =====================================================
*.sql
!docs/postgres_init_blueprint.sql

# =====================================================
# IDE / OS
# =====================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
