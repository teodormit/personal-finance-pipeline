# =====================================================
# Secrets & credentials (NEVER commit)
# =====================================================
.env
*.env
secrets/
credentials/
*.pem
*.key
client_secret_*.json
*-service-account*.json

# Personal account-filter config (real bank-account display names).
# Template lives at config/accounts.example.yaml (committed).
config/accounts.yaml

# =====================================================
# Personal financial data (NEVER commit)
# =====================================================
data/raw/*
data/processed/*
data/archive/*
data/inspection/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/archive/.gitkeep
!data/inspection/.gitkeep

# Spreadsheet exports anywhere in the tree
*.xlsx
*.xls
*.csv

# Tableau workbooks (.twbx packages the real data extract)
data/workbooks/
*.twbx

# Standalone analysis scripts working on personal data
data_check_scripts/
# Cursor state files
.cursor/

# =====================================================
# Database backups (contain real financial data)
# =====================================================
backups/*.dump
backups/*.dump.gpg
!backups/.gitkeep

# =====================================================
# PostgreSQL data dirs (must never be in repo)
# =====================================================
data.backup/
data/base/
data/global/
data/pg_*/
data/postmaster.*
*.conf.backup
postgres_data/
minio_data/

# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# =====================================================
# Logs & temp
# =====================================================
logs/
*.log
tmp/
temp/
*.tmp
*.backup
*.bak

